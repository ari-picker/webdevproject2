<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <title>Dashboard - Quiz Generator</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <!-- Include the Bootstrap navbar partial -->
  <%- include('partials/header') %>
  <div class="container mt-4">
    <!-- <%= %> outputs a value into the HTML. <% %> runs code without outputting -->
    <div class="mb-4">
      <h1 class="display-6">Welcome, <%= name %></h1>
      <p class="lead" style="color: var(--text-muted-custom, #a0a0b8);">Generate a quiz on any topic using AI.</p>
    </div>

    <!-- If the server passed an error message, show it as a red alert -->
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <!-- State 1: No quiz exists yet — show the generation form -->
    <% if (!quiz) { %>
      <div class="card">
        <div class="card-body">
          <!-- POST to /quiz/generate triggers the Groq API call in routes/quiz.js -->
          <form method="POST" action="/quiz/generate">
            <div class="mb-3">
              <label for="topic" class="form-label">Topic</label>
              <input id="topic" type="text" name="topic" class="form-control" placeholder="e.g. World War II, Python programming, Biology" required>
            </div>
            <div class="mb-3">
              <label for="numQuestions" class="form-label">Number of Questions (1-10)</label>
              <input id="numQuestions" type="number" name="numQuestions" class="form-control" value="5" min="1" max="10">
            </div>
            <button type="submit" class="btn btn-primary" id="generateBtn">
              <span id="generateText">Generate Quiz</span>
              <span id="generateSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
            </button>
          </form>
        </div>
      </div>
    <% } %>

    <!-- State 2: Quiz generated but not yet answered — show all questions with radio buttons -->
    <% if (quiz && !result) { %>
      <div class="card mt-3">
        <div class="card-body">
          <h2><%= quiz.title %></h2>
          <form method="POST" action="/quiz/submit">
            <!-- Hidden fields carry the quiz data so the server can score it -->
            <input type="hidden" name="title" value="<%= quiz.title %>">
            <input type="hidden" name="topic" value="<%= quiz.topic %>">
            <input type="hidden" name="questionsJson" value='<%= JSON.stringify(quiz.questions) %>'>
            <!-- Loop through each question — name="q0", name="q1" etc. match req.body["q"+i] in quiz.js -->
            <% quiz.questions.forEach(function(q, i) { %>
              <div class="mb-4 p-3 border rounded">
                <p class="fw-bold"><%= i + 1 %>. <%= q.question %></p>
                <% q.options.forEach(function(opt, j) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="q<%= i %>" value="<%= j %>" id="q<%= i %>_<%= j %>" required>
                    <label class="form-check-label" for="q<%= i %>_<%= j %>"><%= opt %></label>
                  </div>
                <% }); %>
              </div>
            <% }); %>
            <button type="submit" class="btn btn-success">Submit Answers</button>
            <a href="/dashboard" class="btn btn-secondary">New Quiz</a>
          </form>
        </div>
      </div>
    <% } %>

    <!-- State 3: User submitted answers — show score, progress bar, and per-question feedback -->
    <% if (result) { %>
      <div class="card mt-3">
        <div class="card-body">
          <h2>Results</h2>
          <!-- Overall score -->
          <p class="display-6"><%= result.score %> / <%= result.total %> correct</p>
          <!-- Progress bar: color changes based on percentage (green >= 70%, yellow >= 40%, red below) -->
          <div class="progress mb-4">
            <div class="progress-bar <% if (result.score / result.total >= 0.7) { %>bg-success<% } else if (result.score / result.total >= 0.4) { %>bg-warning<% } else { %>bg-danger<% } %>" style="width: <%= (result.score / result.total) * 100 %>%">
              <%= Math.round((result.score / result.total) * 100) %>%
            </div>
          </div>
          <!-- Per-question breakdown — green border for correct, red for wrong -->
          <% result.results.forEach(function(r, i) { %>
            <div class="mb-3 p-3 border rounded <%= r.correct ? 'border-success' : 'border-danger' %>">
              <p class="fw-bold"><%= i + 1 %>. <%= r.question %></p>
              <% r.options.forEach(function(opt, j) { %>
                <div class="form-check">
                  <!-- Disabled radio buttons show the correct answer + user's answer -->
                  <input class="form-check-input" type="radio" disabled
                    <% if (j === r.correctIndex) { %>checked<% } %>
                    <% if (j === r.correctIndex) { %>class="bg-success"<% } %>>
                  <label class="form-check-label <% if (j === r.correctIndex) { %>text-success fw-bold<% } else if (j === r.userAnswer) { %>text-danger<% } %>">
                    <%= opt %>
                    <% if (j === r.correctIndex) { %><span class="badge bg-success">Correct</span><% } %>
                    <% if (j === r.userAnswer && j !== r.correctIndex) { %><span class="badge bg-danger">Your answer</span><% } %>
                  </label>
                </div>
              <% }); %>
            </div>
          <% }); %>
          <a href="/dashboard" class="btn btn-primary">New Quiz</a>
        </div>
      </div>
    <% } %>

    <!-- State 4: History table — only on the initial dashboard, hidden during active quizzes -->
    <% if (history && history.length > 0 && !quiz) { %>
      <div class="card mt-4">
        <div class="card-body">
          <h3>Recent Quiz History</h3>
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Topic</th>
                  <th>Score</th>
                  <th>Percentage</th>
                </tr>
              </thead>
              <tbody>
                <% history.forEach(function(h) { %>
                  <tr>
                    <!-- toLocaleDateString formats the timestamp for the user's local timezone -->
                    <td><%= h.timestamp.toLocaleDateString ? h.timestamp.toLocaleDateString() : h.timestamp %></td>
                    <td><%= h.topic %></td>
                    <td><%= h.score %> / <%= h.total %></td>
                    <td>
                      <!-- Color-coded badge: green >= 70%, yellow >= 40%, red below -->
                      <span class="badge <% if (h.percentage >= 70) { %>bg-success<% } else if (h.percentage >= 40) { %>bg-warning text-dark<% } else { %>bg-danger<% } %>">
                        <%= h.percentage %>%
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } %>
  </div>
  <script>
    // Loading spinner on generate button — shows a spinner and disables the button
    document.querySelector('form[action="/quiz/generate"]')?.addEventListener('submit', function() {
      var btn = document.getElementById('generateBtn');
      if (btn) {
        btn.disabled = true;
        document.getElementById('generateText').textContent = 'Generating...';
        document.getElementById('generateSpinner').classList.remove('d-none');
      }
    });

    // Warn before leaving if a quiz is in progress — but not when submitting the form
    <% if (quiz && !result) { %>
    function onBeforeUnload(e) {
      e.preventDefault();
      e.returnValue = '';
    }
    window.addEventListener('beforeunload', onBeforeUnload);
    document.querySelector('form[action="/quiz/submit"]')?.addEventListener('submit', function() {
      window.removeEventListener('beforeunload', onBeforeUnload);
    });
    <% } %>
  </script>
</body>
</html>
